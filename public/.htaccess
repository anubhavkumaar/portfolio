<IfModule mod_rewrite.c>
  RewriteEngine On

  # SPA Router: Rewrite all requests to index.html for non-existent files/directories
  # This allows clean URLs like /about, /socials etc to work with the SPA router
  RewriteBase /
  
  # Don't rewrite if it's a real file
  RewriteCond %{REQUEST_FILENAME} !-f
  # Don't rewrite if it's a real directory
  RewriteCond %{REQUEST_FILENAME} !-d
  # Don't rewrite the index file itself
  RewriteCond %{REQUEST_FILENAME} !-l
  
  # Rewrite everything else to index.html
  RewriteRule ^(.*)$ index.html [L,QSA]

  # 301 Redirects
  Redirect 301 /discord https://discord.gg/qysMbEXq5R
  Redirect 301 /insta https://www.instagram.com/theanubhavkumar/
  Redirect 301 /youtube https://youtube.com/anubhavkumaar
</IfModule>
